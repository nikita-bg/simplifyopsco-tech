# ElevenLabs настройки
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API (ИЗИСКВА СЕ за LightRAG analytics)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# LightRAG настройки
LIGHTRAG_WORKING_DIR=./lightrag_cache
LIGHTRAG_MODEL_NAME=gpt-4o-mini

# CRM API настройки (за клиенти)
# Тези се конфигурират динамично за всеки клиент
DEFAULT_CRM_API_URL=https://example.com/api/leads
DEFAULT_CRM_BEARER_TOKEN=your_default_token_here

# Сървър настройки
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development

# Security настройки
WEBHOOK_SECRET=your_webhook_secret_here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
