# ============================================
# SimplifyOps — Environment Variables
# Copy to .env and fill in your values
# ============================================

# ============ Backend (Railway) ============

# Neon PostgreSQL (pooled connection for app)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# API Keys
OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...

# Shopify App (from Shopify Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_customers

# Security
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# App Config
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
ALLOWED_ORIGINS=https://simplifyopsco.tech,https://www.simplifyopsco.tech

# ============ Frontend (Vercel) ============

NEXT_PUBLIC_API_URL=https://api.simplifyopsco.tech
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_...
