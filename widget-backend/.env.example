# Server
PORT=3001
NODE_ENV=development

# Supabase (same instance as dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (TTS + Realtime API)
OPENAI_API_KEY=your-openai-api-key

# Widget iframe origin (for CORS)
WIDGET_ORIGIN=https://widget.simplifyops.co

# Shopify/WooCommerce token encryption (same key as next-app)
SHOPIFY_ENCRYPTION_KEY=your-64-char-hex-string-for-aes-256-gcm-encryption

# Sync interval (default: 6 hours in ms)
# SYNC_INTERVAL_MS=21600000
